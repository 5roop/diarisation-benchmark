      <ud-meta-information>
        <ud-information attribute-name="TEXT-ID">ROG-Dia-GSO-P0011</ud-information>
        <ud-information attribute-name="SUBCORPUS">ROG-dialog</ud-information>
        <ud-information attribute-name="TITLE">Govorca sta ženska in moški, oba stara okrog 50 let. Je večer, sedita za kuhinjsko mizo. Ženska postavlja moškemu vprašanja o domačem kraju, običajih in spominih iz otroštva ter mladosti. Moški odgovarja na njena vprašanja, ona pa ga med tem tudi spomni na pomembne točke, ki bi jih lahko vključil v svoje odgovore.</ud-information>
        <ud-information attribute-name="DATE">2025-03</ud-information>
        <ud-information attribute-name="TEXT-REGION">Ljutomer</ud-information>
        <ud-information attribute-name="DOMAIN">Intervju</ud-information>
